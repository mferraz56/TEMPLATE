ENV=development
ENV_FILE=.env.example
FORCE_HTTPS=false
SESSION_COOKIE_SECURE=false
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/template_db
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
SECRET_KEY=change-me

# Port and compose settings.
# POSTGRES_HOST_PORT is optional host exposure. Containers use POSTGRES_INTERNAL_PORT.
APP_PORT=8000
REDIS_PORT=6379
POSTGRES_HOST=db
POSTGRES_INTERNAL_PORT=5432
POSTGRES_HOST_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=template_db
COMPOSE_PROJECT_NAME=template
